#!/usr/bin/env bash
# Block pushes to protected branches (main, master, develop, staging).
# Primary defense is server-side (GitHub Branch Protection Ruleset).
# This hook provides a clear error message to prevent wasted attempts.

PROTECTED_BRANCHES="^(refs/heads/)?(main|master|develop|staging)$"

while read local_ref local_oid remote_ref remote_oid; do
    if [[ "$remote_ref" =~ $PROTECTED_BRANCHES ]]; then
        echo "ERROR: push to protected branch '${remote_ref}' is disabled in this container." >&2
        echo "Create a feature branch and open a pull request instead." >&2
        exit 1
    fi
done

exit 0
